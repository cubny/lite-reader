{
    "name": "cubny/lite-reader",
    "description": "Self-Hosted Lightweight News Reader",
    "keywords": ["rss-reader", "self-hosted", "rss-aggregator", "lite"],
    "homepage": "http://github.com/cubny/lite-reader",
    "license": "MIT",
    "authors": [
        {
            "name": "Alireza Eliaderani",
            "email": "eliaderani@gmail.com",
            "homepage": "http://cubny.com/"
        }
    ],
    "require": {
        "php": ">=7.1",
        "slim/slim": "^3.1",
        "slim/php-view": "^2.0",
        "monolog/monolog": "^1.17",
        "zendframework/zend-feed": "^2.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "LiteReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "process-timeout" : 0
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit --colors=always --testdox --coverage-html build/coverage"
    }

}
